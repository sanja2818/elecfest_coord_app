#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5fef0c1822c0 .scope module, "and_gate_tb" "and_gate_tb" 2 4;
 .timescale -9 -12;
L_0x5fef0c1a7d50 .functor AND 1, v0x5fef0c1a77c0_0, v0x5fef0c1a7890_0, C4<1>, C4<1>;
v0x5fef0c1a77c0_0 .var "a", 0 0;
v0x5fef0c1a7890_0 .var "b", 0 0;
v0x5fef0c1a7960_0 .net "mismatch", 0 0, L_0x5fef0c1a7de0;  1 drivers
v0x5fef0c1a7a30_0 .net "y", 0 0, L_0x5fef0c1a7bf0;  1 drivers
v0x5fef0c1a7b00_0 .net "y_ref", 0 0, L_0x5fef0c1a7d50;  1 drivers
L_0x5fef0c1a7de0 .cmp/nee 1, L_0x5fef0c1a7bf0, L_0x5fef0c1a7d50;
S_0x5fef0c195320 .scope module, "uut" "and_gate" 2 16, 3 1 0, S_0x5fef0c1822c0;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "y";
L_0x5fef0c1a7bf0 .functor AND 1, v0x5fef0c1a77c0_0, v0x5fef0c1a7890_0, C4<1>, C4<1>;
v0x5fef0c181810_0 .net "a", 0 0, v0x5fef0c1a77c0_0;  1 drivers
v0x5fef0c1a75e0_0 .net "b", 0 0, v0x5fef0c1a7890_0;  1 drivers
v0x5fef0c1a76a0_0 .net "y", 0 0, L_0x5fef0c1a7bf0;  alias, 1 drivers
    .scope S_0x5fef0c1822c0;
T_0 ;
    %vpi_call 2 30 "$dumpfile", "and_gate.vcd" {0 0 0};
    %vpi_call 2 31 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5fef0c1822c0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5fef0c1a77c0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5fef0c1a7890_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5fef0c1a77c0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5fef0c1a7890_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5fef0c1a77c0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5fef0c1a7890_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5fef0c1a77c0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5fef0c1a7890_0, 0, 1;
    %delay 10000, 0;
    %vpi_call 2 39 "$finish" {0 0 0};
    %end;
    .thread T_0;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "2_input_and_tb.v";
    "./2_input_and.v";
